{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fab house profile",
  "description": "Manufacturer process capabilities that drive stackup + design-rule + drill setup. UNVERIFIED profiles must set verified=false until checked against the fab's published data.",
  "type": "object",
  "required": ["fab", "verified", "source", "stackups", "rules"],
  "properties": {
    "fab": { "type": "string", "description": "Fab house name, e.g. JLCPCB" },
    "verified": { "type": "boolean", "description": "true only after side-by-side check vs fab docs" },
    "source": { "type": "string", "description": "URL or doc the data came from" },
    "retrieved": { "type": "string", "description": "ISO date the data was captured" },
    "notes": { "type": "string" },
    "stackups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "layer_count", "finished_thickness_mm", "layers"],
        "properties": {
          "name": { "type": "string" },
          "layer_count": { "type": "integer", "minimum": 1 },
          "finished_thickness_mm": { "type": "number", "minimum": 0 },
          "impedance_controlled": { "type": "boolean" },
          "layers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind"],
              "properties": {
                "kind": { "type": "string", "enum": ["Copper", "Core", "PrePreg", "SolderMask", "Surface"] },
                "material": { "type": "string" },
                "thickness_mm": { "type": "number", "minimum": 0 },
                "copper_weight_oz": { "type": "number", "minimum": 0 },
                "dielectric_constant": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "rules": {
      "type": "object",
      "description": "Minimum manufacturable values used to seed design rules and DFM checks.",
      "properties": {
        "min_trace_mm": { "type": "number", "minimum": 0 },
        "min_space_mm": { "type": "number", "minimum": 0 },
        "min_via_diameter_mm": { "type": "number", "minimum": 0 },
        "min_via_drill_mm": { "type": "number", "minimum": 0 },
        "min_annular_ring_mm": { "type": "number", "minimum": 0 },
        "min_hole_to_hole_mm": { "type": "number", "minimum": 0 },
        "copper_to_edge_mm": { "type": "number", "minimum": 0 },
        "min_silk_width_mm": { "type": "number", "minimum": 0 },
        "soldermask_expansion_mm": { "type": "number" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
