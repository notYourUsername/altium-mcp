{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "get_pcb_layer_stackup response",
  "type": "object",
  "required": [
    "total_layers",
    "total_thickness_mils",
    "total_thickness_mm",
    "board_name",
    "layers"
  ],
  "properties": {
    "total_layers": { "type": "integer", "minimum": 1 },
    "total_copper_layers": { "type": "integer", "minimum": 1 },
    "total_dielectric_layers": { "type": "integer", "minimum": 0 },
    "total_thickness_mils": { "type": "number", "minimum": 0 },
    "total_thickness_mm": { "type": "number", "minimum": 0 },
    "board_name": { "type": "string" },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "layer_name",
          "layer_id",
          "material_type",
          "copper_thickness_mils",
          "dielectric_type",
          "layer_order"
        ],
        "properties": {
          "layer_name": { "type": "string" },
          "layer_id": { "type": "string" },
          "material_type": { "type": "string" },
          "copper_thickness_mils": { "type": "number", "minimum": 0 },
          "copper_thickness_um": { "type": "number", "minimum": 0 },
          "dielectric_type": {
            "type": "string",
            "enum": ["Core", "PrePreg", "Surface Material", "No Dielectric", "Unknown"]
          },
          "dielectric_material": { "type": "string" },
          "dielectric_height_mils": { "type": "number", "minimum": 0 },
          "dielectric_height_um": { "type": "number", "minimum": 0 },
          "dielectric_constant": { "type": "number", "minimum": 0 },
          "layer_order": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
