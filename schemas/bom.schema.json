{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "get_bom response",
  "type": "object",
  "required": ["total_components", "total_lines", "bom"],
  "properties": {
    "total_components": { "type": "integer", "minimum": 0 },
    "total_lines": { "type": "integer", "minimum": 0 },
    "bom": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "footprint", "quantity", "designators"],
        "properties": {
          "description": { "type": "string" },
          "footprint": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "designators": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
