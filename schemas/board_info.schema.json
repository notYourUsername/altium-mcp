{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "get_board_info response",
  "type": "object",
  "required": ["board_name", "signal_layer_count", "total_thickness_mm", "total_thickness_mils"],
  "properties": {
    "board_name": { "type": "string" },
    "display_unit": { "type": "string", "enum": ["mm", "mil"] },
    "width_mm": { "type": "number", "minimum": 0 },
    "height_mm": { "type": "number", "minimum": 0 },
    "width_mils": { "type": "number", "minimum": 0 },
    "height_mils": { "type": "number", "minimum": 0 },
    "origin_x_mm": { "type": "number" },
    "origin_y_mm": { "type": "number" },
    "origin_x_mils": { "type": "number" },
    "origin_y_mils": { "type": "number" },
    "signal_layer_count": { "type": "integer", "minimum": 0 },
    "total_thickness_mils": { "type": "number", "minimum": 0 },
    "total_thickness_mm": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": true
}
