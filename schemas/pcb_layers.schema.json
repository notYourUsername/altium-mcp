{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "get_pcb_layers response",
  "type": "object",
  "required": ["copper_layers_count", "copper_layers"],
  "properties": {
    "copper_layers_count": { "type": "integer", "minimum": 1 },
    "signal_layers_count": { "type": "integer", "minimum": 0 },
    "internal_planes_count": { "type": "integer", "minimum": 0 },
    "mechanical_layers_count": { "type": "integer", "minimum": 0 },
    "copper_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "layer_id", "layer_type"],
        "properties": {
          "name": { "type": "string" },
          "layer_id": { "type": "string" },
          "layer_type": { "type": "string" },
          "is_signal": { "type": "boolean" },
          "is_plane": { "type": "boolean" },
          "is_displayed": { "type": "boolean" },
          "is_enabled": { "type": "boolean" },
          "color": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "mechanical_layers": { "type": "array", "items": { "type": "object" } },
    "special_layers": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
